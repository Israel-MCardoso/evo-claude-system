{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "outDir": ".test-dist",
    "rootDir": ".",
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/server/**/*.test.ts", "src/server/**/*.ts", "src/features/checkout/**/*.test.ts", "src/features/checkout/address-autocomplete.ts"]
}
